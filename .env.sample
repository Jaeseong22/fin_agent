MYSQL_USER=finagent
MYSQL_PASSWORD=finagent
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=fin_agent

# Required: OpenAI model calls
OPENAI_API_KEY=

# Optional: only needed to record traces in your own LangSmith workspace.
# Public prompts are pulled from jaeseong22/* without this key.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=fin_agent

# Note: copy this file to .env and fill values. Do NOT commit real secrets.
